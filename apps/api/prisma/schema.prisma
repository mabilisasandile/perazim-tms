// Perazim Fleet Management - Prisma Schema
// Redesigned from PHP/CodeIgniter source

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// AUTH & USERS
// ─────────────────────────────────────────────

model User {
  id                Int       @id @default(autoincrement())
  name              String
  email             String    @unique
  username          String    @unique
  password          String
  role              String    @default("ADMIN")
  isActive          Boolean   @default(true)
  failedLoginCount  Int       @default(0)
  lockedUntil       DateTime?
  lastLoginAt       DateTime?
  passwordChangedAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  permissions UserPermissions?
  trips       Trip[]           @relation("TripCreatedBy")

  @@index([role])
  @@map("users")
}

model UserPermissions {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Vehicle permissions
  vehicleList        Boolean @default(false)
  vehicleView        Boolean @default(false)
  vehicleEdit        Boolean @default(false)
  vehicleAdd         Boolean @default(false)
  vehicleGroup       Boolean @default(false)
  vehicleGroupAdd    Boolean @default(false)
  vehicleGroupAction Boolean @default(false)

  // Driver permissions
  driverList Boolean @default(false)
  driverEdit Boolean @default(false)
  driverAdd  Boolean @default(false)

  // Trip permissions
  tripList Boolean @default(false)
  tripEdit Boolean @default(false)
  tripAdd  Boolean @default(false)

  // Customer permissions
  customerList Boolean @default(false)
  customerEdit Boolean @default(false)
  customerAdd  Boolean @default(false)

  // Fuel permissions
  fuelList Boolean @default(false)
  fuelEdit Boolean @default(false)
  fuelAdd  Boolean @default(false)

  // Reminder permissions
  reminderList   Boolean @default(false)
  reminderDelete Boolean @default(false)
  reminderAdd    Boolean @default(false)

  // Income/Expense permissions
  incomeExpenseList Boolean @default(false)
  incomeExpenseEdit Boolean @default(false)

  @@map("user_permissions")
}

// ─────────────────────────────────────────────
// CUSTOMERS
// ─────────────────────────────────────────────

model Customer {
  id               Int      @id @default(autoincrement())
  name             String
  email            String   @unique
  phone            String?
  address          String?  @db.Text
  password         String? // bcrypt hashed — for customer portal login
  resetToken       String?
  isActive         Boolean  @default(true)
  payLaterApproved Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  trips      Trip[]
  quotations Quotation[]
  invoices   Invoice[]

  @@map("customers")
}

// ─────────────────────────────────────────────
// VEHICLES
// ─────────────────────────────────────────────

model VehicleGroup {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())

  vehicles Vehicle[]

  @@map("vehicle_groups")
}

model Vehicle {
  id                 Int           @id @default(autoincrement())
  registrationNo     String        @unique
  name               String
  chassisNo          String
  engineNo           String
  apiUsername        String? // Cartrack Equipment ID
  groupId            Int?
  group              VehicleGroup? @relation(fields: [groupId], references: [id])
  registrationExpiry DateTime?
  isActive           Boolean       @default(true)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  drivers           Driver[]
  trips             Trip[]
  fuel              Fuel[]
  positions         Position[]
  geofences         GeofenceVehicle[]
  geofenceEvents    GeofenceEvent[]
  reminders         Reminder[]
  incomeExpenses    IncomeExpense[]
  loadSheets        LoadSheet[]
  assignedTrailers  Trailer[]         @relation("VehicleAssignedTrailers")
  flatDeckJobs      FlatDeckJob[]     @relation("FlatDeckVehicle")

  @@map("vehicles")
}

// ─────────────────────────────────────────────
// TRAILERS
// ─────────────────────────────────────────────

model Trailer {
  id                Int       @id @default(autoincrement())
  registrationNo    String    @unique
  make              String?
  type              String?   // legacy free-text field
  category          String?   // Flat Deck | Superlink | Lowbed | Tautliner
  chassisNo         String?
  loadCapacity      Float?
  colour            String?
  licenseNo         String?
  licenseExpiry     DateTime?
  status            String    @default("Available") // Available | In Use | Under Maintenance
  isActive          Boolean   @default(true)
  assignedVehicleId Int?
  assignedVehicle   Vehicle?  @relation("VehicleAssignedTrailers", fields: [assignedVehicleId], references: [id], onDelete: SetNull)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  drivers       Driver[]
  trips         Trip[]
  loadSheets    LoadSheet[]
  flatDeckJobs  FlatDeckJob[]

  @@map("trailers")
}

// ─────────────────────────────────────────────
// DRIVERS
// ─────────────────────────────────────────────

model Driver {
  id                Int       @id @default(autoincrement())
  name              String
  mobile            String
  email             String    @unique
  age               Int?
  address           String?   @db.Text
  licenseNo         String
  licenseExpiry     DateTime?
  totalExperience   String?
  dateOfJoining     DateTime?
  reference         String?
  password          String? // bcrypt hashed — for driver app login
  resetToken        String?
  isActive          Boolean   @default(true)
  assignedVehicleId Int?
  assignedVehicle   Vehicle?  @relation(fields: [assignedVehicleId], references: [id])
  assignedTrailerId Int?
  assignedTrailer   Trailer?  @relation(fields: [assignedTrailerId], references: [id])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  trips            Trip[]
  tripLegs         TripLeg[]
  fuel             Fuel[]
  timesheets       Timesheet[]
  loadSheets       LoadSheet[]
  driverExpenses   DriverExpense[]
  inspections      Inspection[]
  inspectionImages InspectionImage[]
  documents        DriverDocument[]
  emergencyContacts DriverEmergencyContact[]
  incidents        DriverIncident[]
  warnings         DriverWarning[]
  payrollConfig    DriverPayrollConfig?
  payrollEntries   PayrollEntry[]

  @@map("drivers")
}

// ─────────────────────────────────────────────
// TRIPS
// ─────────────────────────────────────────────

enum TripStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TripType {
  SINGLE
  MULTI_LEG
}

model Trip {
  id           Int        @id @default(autoincrement())
  trackingCode String     @unique @default(cuid())
  type         TripType   @default(SINGLE)
  status       TripStatus @default(PENDING)

  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])
  vehicleId  Int
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id])
  driverId   Int
  driver     Driver   @relation(fields: [driverId], references: [id])
  trailerId  Int?
  trailer    Trailer? @relation(fields: [trailerId], references: [id])

  fromLocation String
  toLocation   String
  fromLat      Float?
  fromLng      Float?
  toLat        Float?
  toLng        Float?
  startDate    DateTime
  endDate      DateTime?

  // Customer's vehicle being transported
  customerVehicleMake         String?
  customerVehicleColour       String?
  customerVehicleRegistration String?
  customerVehicleVin          String?
  customerVehicleStock        String?
  customerVehicleEngine       String?
  vehicleCondition            String? // Runner | Non-Runner

  // Trip financials
  amount      Decimal? @db.Decimal(10, 2)
  vatAmount   Decimal? @db.Decimal(10, 2)
  totalAmount Decimal? @db.Decimal(10, 2)

  // Vehicle condition photos (up to 8)
  picture1 String?
  picture2 String?
  picture3 String?
  picture4 String?
  picture5 String?
  picture6 String?
  picture7 String?
  picture8 String?

  createdById Int?
  createdBy   User?    @relation("TripCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  legs             TripLeg[]
  payment          TripPayment?
  expenses         TripExpense[]
  inspections      Inspection[]
  inspectionImages InspectionImage[]
  positions        Position[]
  warehouseVehicle WarehouseVehicle?
  gateScans           GateScan[]
  proofOfDelivery     ProofOfDelivery?
  deliveryOtp         DeliveryOtp?
  customerCollection  CustomerCollection?
  payrollLinks        PayrollTripLink[]
  invoices            Invoice[]

  @@map("trips")
}

model TripLeg {
  id            Int       @id @default(autoincrement())
  tripId        Int
  trip          Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  driverId      Int
  driver        Driver    @relation(fields: [driverId], references: [id])
  startLocation String
  endLocation   String
  scheduledAt   DateTime?
  completedAt   DateTime?
  order         Int       @default(1)
  status        String    @default("pending") // pending | completed

  @@map("trip_legs")
}

model TripExpense {
  id          Int      @id @default(autoincrement())
  tripId      Int
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  description String
  amount      Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  @@map("trip_expenses")
}

model TripPayment {
  id        Int       @id @default(autoincrement())
  tripId    Int       @unique
  trip      Trip      @relation(fields: [tripId], references: [id])
  vehicleId Int
  amount    Decimal   @db.Decimal(10, 2)
  method    String    @default("payfast") // payfast | manual | eft
  status    String    @default("pending") // pending | paid | failed
  reference String?
  paidAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("trip_payments")
}

// ─────────────────────────────────────────────
// QUOTATIONS
// ─────────────────────────────────────────────

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
  CONVERTED
}

model Quotation {
  id          Int             @id @default(autoincrement())
  number      String?         @unique
  customerId  Int
  customer    Customer        @relation(fields: [customerId], references: [id])
  information String?         @db.Text
  pickup      String
  dropoff     String
  pickupLat   Float?
  pickupLng   Float?
  dropoffLat  Float?
  dropoffLng  Float?
  distance    Float?
  pickupDate  DateTime?
  dropoffDate DateTime?
  status      QuotationStatus @default(DRAFT)
  isConverted Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  items QuotationItem[]

  @@map("quotations")
}

model QuotationItem {
  id               Int       @id @default(autoincrement())
  quotationId      Int
  quotation        Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  description      String
  colour           String?
  registration     String?
  vehicleCondition String? // Runner | Non-Runner
  quantity         Int       @default(1)
  unitPrice        Decimal   @db.Decimal(10, 2)
  total            Decimal   @db.Decimal(10, 2)

  @@map("quotation_items")
}

// ─────────────────────────────────────────────
// INVOICES
// ─────────────────────────────────────────────

model Invoice {
  id                 Int       @id @default(autoincrement())
  number             String    @unique
  customerId         Int
  customer           Customer  @relation(fields: [customerId], references: [id])
  tripId             Int?
  trip               Trip?     @relation(fields: [tripId], references: [id])
  amount             Decimal   @db.Decimal(10, 2)
  vatAmount          Decimal   @db.Decimal(10, 2)
  total              Decimal   @db.Decimal(10, 2)
  depositRequired    Decimal?  @db.Decimal(10, 2)
  depositPaid        Decimal   @default(0) @db.Decimal(10, 2)
  amountPaid         Decimal   @default(0) @db.Decimal(10, 2)
  status             String    @default("unpaid") // unpaid | partial | paid | overdue
  dueDate            DateTime?
  paidAt             DateTime?
  notes              String?   @db.Text
  vehicleDescription String?
  vehicleCondition   String? // Runner | Non-Runner
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  items    InvoiceItem[]
  payments InvoicePayment[]

  @@map("invoices")
}

model InvoiceItem {
  id               Int     @id @default(autoincrement())
  invoiceId        Int
  invoice          Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description      String
  vehicleCondition String?
  quantity         Int     @default(1)
  unitPrice        Decimal @db.Decimal(10, 2)
  total            Decimal @db.Decimal(10, 2)

  @@index([invoiceId])
  @@map("invoice_items")
}

model InvoicePayment {
  id        Int      @id @default(autoincrement())
  invoiceId Int
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  type      String   @default("PAYMENT") // DEPOSIT | PAYMENT
  amount    Decimal  @db.Decimal(10, 2)
  method    String   @default("manual") // payfast | manual | eft | cash
  reference String?
  proofPath String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@map("invoice_payments")
}

// ─────────────────────────────────────────────
// FUEL
// ─────────────────────────────────────────────

model Fuel {
  id           Int      @id @default(autoincrement())
  vehicleId    Int
  vehicle      Vehicle  @relation(fields: [vehicleId], references: [id])
  driverId     Int?
  driver       Driver?  @relation(fields: [driverId], references: [id])
  litres       Float
  costPerLitre Decimal  @db.Decimal(10, 2)
  totalCost    Decimal  @db.Decimal(10, 2)
  odometer     Float?
  fillDate     DateTime
  notes        String?
  createdAt    DateTime @default(now())

  @@map("fuel")
}

// ─────────────────────────────────────────────
// INCOME & EXPENSES
// ─────────────────────────────────────────────

enum IncomeExpenseType {
  INCOME
  EXPENSE
}

model IncomeExpense {
  id          Int               @id @default(autoincrement())
  vehicleId   Int?
  vehicle     Vehicle?          @relation(fields: [vehicleId], references: [id])
  type        IncomeExpenseType
  description String
  amount      Decimal           @db.Decimal(10, 2)
  date        DateTime
  createdAt   DateTime          @default(now())

  @@map("income_expenses")
}

model DriverExpense {
  id          Int      @id @default(autoincrement())
  driverId    Int
  driver      Driver   @relation(fields: [driverId], references: [id])
  description String
  amount      Decimal  @db.Decimal(10, 2)
  date        DateTime
  createdAt   DateTime @default(now())

  @@map("driver_expenses")
}

// ─────────────────────────────────────────────
// GEOFENCING
// ─────────────────────────────────────────────

model Geofence {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  area        Json // GeoJSON polygon coordinates
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vehicles GeofenceVehicle[]
  events   GeofenceEvent[]

  @@map("geofences")
}

model GeofenceVehicle {
  geofenceId Int
  geofence   Geofence @relation(fields: [geofenceId], references: [id], onDelete: Cascade)
  vehicleId  Int
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@id([geofenceId, vehicleId])
  @@map("geofence_vehicles")
}

model GeofenceEvent {
  id         Int      @id @default(autoincrement())
  vehicleId  Int
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id])
  geofenceId Int
  geofence   Geofence @relation(fields: [geofenceId], references: [id])
  eventType  String // entered | exited
  latitude   Float
  longitude  Float
  occurredAt DateTime @default(now())

  @@map("geofence_events")
}

// ─────────────────────────────────────────────
// GPS POSITIONS
// ─────────────────────────────────────────────

model Position {
  id         Int      @id @default(autoincrement())
  tripId     Int?
  trip       Trip?    @relation(fields: [tripId], references: [id])
  vehicleId  Int
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id])
  latitude   Float
  longitude  Float
  altitude   Float?
  speed      Float?
  bearing    Float?
  accuracy   Float?
  recordedAt DateTime @default(now())

  @@map("positions")
}

// ─────────────────────────────────────────────
// INSPECTIONS
// ─────────────────────────────────────────────

model InspectionCategory {
  id       Int     @id @default(autoincrement())
  name     String
  isActive Boolean @default(true)
  order    Int     @default(0)

  items InspectionItem[]

  @@map("inspection_categories")
}

model InspectionItem {
  id         Int                @id @default(autoincrement())
  categoryId Int
  category   InspectionCategory @relation(fields: [categoryId], references: [id])
  name       String
  isActive   Boolean            @default(true)
  order      Int                @default(0)

  @@map("inspection_items")
}

model Inspection {
  id        Int      @id @default(autoincrement())
  tripId    Int
  trip      Trip     @relation(fields: [tripId], references: [id])
  driverId  Int
  driver    Driver   @relation(fields: [driverId], references: [id])
  // COLLECTION | WAREHOUSE | HANDOVER | DELIVERY
  stage     String   @default("COLLECTION")
  data      Json     // { itemId: pass|fail|na, ... }
  remarks   String?  @db.Text

  // Vehicle condition metrics
  odometerReading  Float?
  fuelLevel        Int?    // 0-100 percentage

  // Damage
  damageNotes      String? @db.Text

  // Signatures (base64 PNG)
  driverSignature   String? @db.LongText
  receiverName      String?
  receiverSignature String? @db.LongText

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images InspectionImage[]

  @@index([stage])
  @@map("inspections")
}

model InspectionImage {
  id           Int         @id @default(autoincrement())
  tripId       Int
  trip         Trip        @relation(fields: [tripId], references: [id])
  driverId     Int
  driver       Driver      @relation(fields: [driverId], references: [id])
  inspectionId Int?
  inspection   Inspection? @relation(fields: [inspectionId], references: [id])
  filename     String
  path         String
  createdAt    DateTime    @default(now())

  @@map("inspection_images")
}

// ─────────────────────────────────────────────
// LOAD SHEETS
// ─────────────────────────────────────────────

model LoadSheet {
  id        Int      @id @default(autoincrement())
  driverId  Int
  driver    Driver   @relation(fields: [driverId], references: [id])
  vehicleId Int
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
  trailerId Int?
  trailer   Trailer? @relation(fields: [trailerId], references: [id])
  data      Json // flexible load data
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("load_sheets")
}

// ─────────────────────────────────────────────
// TIMESHEETS
// ─────────────────────────────────────────────

model Timesheet {
  id        Int       @id @default(autoincrement())
  driverId  Int
  driver    Driver    @relation(fields: [driverId], references: [id])
  clockIn   DateTime
  clockOut  DateTime?
  notes     String?
  createdAt DateTime  @default(now())

  @@map("timesheets")
}

// ─────────────────────────────────────────────
// REMINDERS
// ─────────────────────────────────────────────

model Reminder {
  id          Int      @id @default(autoincrement())
  vehicleId   Int?
  vehicle     Vehicle? @relation(fields: [vehicleId], references: [id])
  title       String
  description String?  @db.Text
  dueDate     DateTime
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("reminders")
}

// ─────────────────────────────────────────────
// SETTINGS
// ─────────────────────────────────────────────

model Settings {
  id           Int      @id @default(autoincrement())
  companyName  String   @default("Perazim")
  logo         String?
  phone        String?
  email        String?
  address      String?  @db.Text
  website      String?
  vat          Float    @default(15)
  currency     String   @default("ZAR")
  googleApiKey String?
  // Security policy
  minPasswordLength     Int     @default(8)
  requireUppercase      Boolean @default(false)
  requireNumbers        Boolean @default(false)
  requireSpecialChars   Boolean @default(false)
  sessionTimeoutMinutes Int     @default(15)
  maxLoginAttempts      Int     @default(5)
  lockoutMinutes        Int     @default(30)
  updatedAt             DateTime @updatedAt

  @@map("settings")
}

model SmtpSettings {
  id        Int      @id @default(autoincrement())
  host      String
  port      Int      @default(587)
  secure    Boolean  @default(false)
  username  String
  password  String
  fromEmail String
  replyTo   String?
  updatedAt DateTime @updatedAt

  @@map("smtp_settings")
}

// ─────────────────────────────────────────────
// AUDIT TRAIL
// ─────────────────────────────────────────────

model AuditLog {
  id         Int      @id @default(autoincrement())
  username   String
  ipAddress  String?
  actionType String
  entityType String
  entityId   Int?
  oldValue   Json?
  newValue   Json?
  createdAt  DateTime @default(now())

  @@index([username])
  @@index([actionType])
  @@index([entityType])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// WAREHOUSE MANAGEMENT
// ─────────────────────────────────────────────

model Warehouse {
  id           Int      @id @default(autoincrement())
  name         String
  location     String
  capacity     Int      // max vehicle slots
  contactName  String?
  contactPhone String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  vehicles      WarehouseVehicle[]
  transfersFrom WarehouseTransfer[] @relation("TransferFromWarehouse")
  transfersTo   WarehouseTransfer[] @relation("TransferToWarehouse")

  @@map("warehouses")
}

model WarehouseVehicle {
  id           Int       @id @default(autoincrement())
  warehouseId  Int
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id])
  tripId       Int       @unique
  trip         Trip      @relation(fields: [tripId], references: [id])
  // IN_STORAGE | AWAITING_DISPATCH | DISPATCHED
  status       String    @default("IN_STORAGE")
  arrivedAt    DateTime  @default(now())
  dispatchedAt DateTime?
  notes        String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  transfers WarehouseTransfer[]

  @@map("warehouse_vehicles")
}

model WarehouseTransfer {
  id                 Int              @id @default(autoincrement())
  warehouseVehicleId Int
  warehouseVehicle   WarehouseVehicle @relation(fields: [warehouseVehicleId], references: [id])
  fromWarehouseId    Int
  fromWarehouse      Warehouse        @relation("TransferFromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouseId      Int
  toWarehouse        Warehouse        @relation("TransferToWarehouse", fields: [toWarehouseId], references: [id])
  transferredAt      DateTime         @default(now())
  notes              String?          @db.Text

  @@map("warehouse_transfers")
}

// ─────────────────────────────────────────────
// SECURITY GATE SCANNING
// ─────────────────────────────────────────────

model GateScan {
  id            Int      @id @default(autoincrement())
  // ENTRY | EXIT
  scanType      String
  trackingCode  String
  tripId        Int?
  trip          Trip?    @relation(fields: [tripId], references: [id])

  // Driver at the gate
  driverName    String?
  driverLicense String?
  driverPhone   String?

  // Transport / tow truck
  towTruckReg   String?
  towTruckDriver String?

  // Security officer (exit)
  officerName   String?
  isApproved    Boolean  @default(false)

  // Gate location
  gateName      String?

  scannedAt     DateTime @default(now())
  notes         String?  @db.Text

  @@index([trackingCode])
  @@index([scanType])
  @@index([scannedAt])
  @@map("gate_scans")
}

// ─────────────────────────────────────────────
// PROOF OF DELIVERY
// ─────────────────────────────────────────────

model ProofOfDelivery {
  id          Int      @id @default(autoincrement())
  tripId      Int      @unique
  trip        Trip     @relation(fields: [tripId], references: [id])

  // Receiver Information
  receiverFirstName   String
  receiverLastName    String
  receiverPhone       String
  receiverEmail       String?
  receiverIdNumber    String?
  relationshipToOwner String?

  // Delivery Verification
  signature       String   @db.LongText
  gpsLatitude     Float?
  gpsLongitude    Float?
  gpsAccuracy     Float?
  deliveredAt     DateTime @default(now())
  notes           String?  @db.Text

  photos    PodPhoto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("proofs_of_delivery")
}

model PodPhoto {
  id        Int             @id @default(autoincrement())
  podId     Int
  pod       ProofOfDelivery @relation(fields: [podId], references: [id], onDelete: Cascade)
  filename  String
  path      String
  createdAt DateTime        @default(now())

  @@map("pod_photos")
}

// ─────────────────────────────────────────────
// CUSTOMER COLLECTION
// ─────────────────────────────────────────────

model CustomerCollection {
  id     Int  @id @default(autoincrement())
  tripId Int  @unique
  trip   Trip @relation(fields: [tripId], references: [id])

  // Collector identity
  collectorFirstName  String
  collectorLastName   String
  collectorPhone      String
  collectorEmail      String?
  relationshipToOwner String?

  // Identity verification
  idType      String  // South African ID | Passport | Driver's License | Other
  idNumber    String
  idPhotoPath String? // path to uploaded ID document photo

  // Selfie (anti-fraud)
  selfiePath String? // path to captured selfie photo

  // Digital signature
  signature String @db.LongText

  // GPS at time of collection
  gpsLatitude  Float?
  gpsLongitude Float?
  gpsAccuracy  Float?

  // Confirmation
  collectedAt DateTime @default(now())
  notes       String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tripId])
  @@map("customer_collections")
}

// ─────────────────────────────────────────────
// DRIVER DOCUMENTATION
// ─────────────────────────────────────────────

model DriverDocument {
  id         Int      @id @default(autoincrement())
  driverId   Int
  driver     Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  // DRIVER_LICENSE | PDP | PASSPORT | WORK_PERMIT | DRIVER_PHOTO | EMPLOYMENT_CONTRACT | OTHER
  type       String
  label      String?
  filename   String
  path       String
  expiryDate DateTime?
  notes      String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([driverId])
  @@index([type])
  @@index([expiryDate])
  @@map("driver_documents")
}

model DriverEmergencyContact {
  id           Int     @id @default(autoincrement())
  driverId     Int
  driver       Driver  @relation(fields: [driverId], references: [id], onDelete: Cascade)
  name         String
  relationship String
  phone        String
  altPhone     String?
  email        String?
  address      String? @db.Text
  isPrimary    Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([driverId])
  @@map("driver_emergency_contacts")
}

model DriverIncident {
  id           Int      @id @default(autoincrement())
  driverId     Int
  driver       Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  incidentDate DateTime
  title        String
  description  String   @db.Text
  // MINOR | MODERATE | MAJOR
  severity     String   @default("MINOR")
  // OPEN | UNDER_INVESTIGATION | CLOSED
  status       String   @default("OPEN")
  notes        String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([driverId])
  @@map("driver_incidents")
}

model DriverWarning {
  id           Int      @id @default(autoincrement())
  driverId     Int
  driver       Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  warningDate  DateTime
  // VERBAL | WRITTEN | FINAL
  type         String
  reason       String
  description  String   @db.Text
  issuedBy     String
  acknowledged Boolean  @default(false)
  notes        String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([driverId])
  @@map("driver_warnings")
}

// ─────────────────────────────────────────────
// OTP DELIVERY VERIFICATION
// ─────────────────────────────────────────────

model DeliveryOtp {
  id          Int       @id @default(autoincrement())
  tripId      Int       @unique
  trip        Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)

  codeHash     String   // bcrypt hash of 6-digit code
  sentTo       String   // email address OTP was sent to
  expiresAt    DateTime
  verified     Boolean  @default(false)
  verifiedAt   DateTime?
  attempts     Int      @default(0)

  // Admin bypass
  bypassedBy   Int?     // userId who approved bypass
  bypassedAt   DateTime?
  bypassReason String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tripId])
  @@map("delivery_otps")
}

// ─────────────────────────────────────────────
// PAYROLL
// ─────────────────────────────────────────────

model PayrollSetting {
  id                Int      @id @default(autoincrement())
  baseEnabled       Boolean  @default(false)
  defaultBaseSalary Decimal? @db.Decimal(10, 2)
  tripRateEnabled   Boolean  @default(true)
  defaultTripRate   Decimal? @db.Decimal(10, 2)
  commissionEnabled Boolean  @default(false)
  commissionRate    Float?
  currency          String   @default("ZAR")
  updatedAt         DateTime @updatedAt

  @@map("payroll_settings")
}

model DriverPayrollConfig {
  id             Int      @id @default(autoincrement())
  driverId       Int      @unique
  driver         Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  baseSalary     Decimal? @db.Decimal(10, 2)
  tripRate       Decimal? @db.Decimal(10, 2)
  commissionRate Float?
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("driver_payroll_configs")
}

model PayrollEntry {
  id            Int      @id @default(autoincrement())
  driverId      Int
  driver        Driver   @relation(fields: [driverId], references: [id])
  // WEEKLY | MONTHLY
  periodType    String
  periodStart   DateTime
  periodEnd     DateTime
  // Earnings
  baseSalary    Decimal  @db.Decimal(10, 2) @default(0)
  tripCount     Int      @default(0)
  tripEarnings  Decimal  @db.Decimal(10, 2) @default(0)
  commissions   Decimal  @db.Decimal(10, 2) @default(0)
  bonuses       Decimal  @db.Decimal(10, 2) @default(0)
  deductions    Decimal  @db.Decimal(10, 2) @default(0)
  grossPay      Decimal  @db.Decimal(10, 2) @default(0)
  netPay        Decimal  @db.Decimal(10, 2) @default(0)
  // Status: DRAFT | APPROVED | PAID | OUTSTANDING
  status        String   @default("DRAFT")
  approvedAt    DateTime?
  approvedBy    String?
  paidAt        DateTime?
  paymentMethod String?
  paymentRef    String?
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tripLinks     PayrollTripLink[]

  @@index([driverId])
  @@index([status])
  @@index([periodStart])
  @@map("payroll_entries")
}

model PayrollTripLink {
  id             Int          @id @default(autoincrement())
  payrollEntryId Int
  payrollEntry   PayrollEntry @relation(fields: [payrollEntryId], references: [id], onDelete: Cascade)
  tripId         Int
  trip           Trip         @relation(fields: [tripId], references: [id])
  tripAmount     Decimal      @db.Decimal(10, 2) @default(0)
  tripRate       Decimal      @db.Decimal(10, 2) @default(0)
  commission     Decimal      @db.Decimal(10, 2) @default(0)
  driverEarnings Decimal      @db.Decimal(10, 2) @default(0)
  createdAt      DateTime     @default(now())

  @@unique([payrollEntryId, tripId])
  @@index([payrollEntryId])
  @@map("payroll_trip_links")
}

// ─────────────────────────────────────────────
// FLAT DECK DIVISION
// ─────────────────────────────────────────────

enum FlatDeckTrailerType {
  FLAT_12M            // 12m Flat Deck
  SUPERLINK_FLAT_DECK // Superlink Flat Deck
  TAUTLINER
  LOWBED
}

model FlatDeckJob {
  id          Int                @id @default(autoincrement())
  reference   String             @unique
  trailerType FlatDeckTrailerType
  trailerId   Int?
  trailer     Trailer?           @relation(fields: [trailerId], references: [id])
  vehicleId   Int?
  vehicle     Vehicle?           @relation("FlatDeckVehicle", fields: [vehicleId], references: [id])
  driverName  String?
  origin      String
  destination String
  plannedDate DateTime
  deliveredAt DateTime?
  // PLANNED | LOADING | IN_TRANSIT | DELIVERED | CANCELLED
  status      String             @default("PLANNED")
  totalWeight Float              @default(0)
  notes       String?            @db.Text
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  cargo FlatDeckCargo[]

  @@map("flat_deck_jobs")
}

model FlatDeckCargo {
  id                 Int         @id @default(autoincrement())
  jobId              Int
  job                FlatDeckJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  description        String
  quantity           Int         @default(1)
  weightPerUnit      Float
  totalWeight        Float
  lengthM            Float?
  widthM             Float?
  heightM            Float?
  // STANDARD | OVERSIZED | HAZARDOUS | FRAGILE | HEAVY_LIFT
  specialRequirement String      @default("STANDARD")
  notes              String?

  @@map("flat_deck_cargo")
}

model FlatDeckRoute {
  id              Int      @id @default(autoincrement())
  name            String
  origin          String
  destination     String
  distanceKm      Float?
  maxWeightTonnes Float?
  maxHeightM      Float?
  maxLengthM      Float?
  allows12mFlat   Boolean  @default(true)
  allowsSuperlink Boolean  @default(true)
  allowsTautliner Boolean  @default(true)
  allowsLowbed    Boolean  @default(true)
  notes           String?  @db.Text
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("flat_deck_routes")
}

// ─────────────────────────────────────────────
// FUEL TANKER DIVISION
// ─────────────────────────────────────────────

enum FuelProductType {
  DIESEL
  PETROL
  PARAFFIN
}

model FuelTanker {
  id             Int      @id @default(autoincrement())
  name           String
  registrationNo String   @unique
  totalCapacity  Float
  isActive       Boolean  @default(true)
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  compartments TankerCompartment[]
  deliveries   TankerDelivery[]
  loads        TankerLoad[]

  @@map("fuel_tankers")
}

model TankerCompartment {
  id            Int             @id @default(autoincrement())
  tankerId      Int
  tanker        FuelTanker      @relation(fields: [tankerId], references: [id], onDelete: Cascade)
  compartmentNo Int
  capacity      Float
  fuelType      FuelProductType
  currentVolume Float           @default(0)
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([tankerId, compartmentNo])
  @@map("tanker_compartments")
}

model TankerDelivery {
  id          Int        @id @default(autoincrement())
  reference   String     @unique
  tankerId    Int
  tanker      FuelTanker @relation(fields: [tankerId], references: [id])
  driverName  String?
  // PLANNED | LOADING | IN_TRANSIT | COMPLETED | CANCELLED
  status      String     @default("PLANNED")
  plannedDate DateTime
  departedAt  DateTime?
  completedAt DateTime?
  notes       String?    @db.Text
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  stops TankerDeliveryStop[]

  @@map("tanker_deliveries")
}

model TankerDeliveryStop {
  id              Int             @id @default(autoincrement())
  deliveryId      Int
  delivery        TankerDelivery  @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  order           Int             @default(1)
  customerName    String
  address         String
  fuelType        FuelProductType
  plannedVolume   Float
  deliveredVolume Float           @default(0)
  // PENDING | DELIVERED | SKIPPED
  status          String          @default("PENDING")
  deliveredAt     DateTime?
  notes           String?         @db.Text

  @@map("tanker_delivery_stops")
}

model TankerLoad {
  id            Int             @id @default(autoincrement())
  tankerId      Int
  tanker        FuelTanker      @relation(fields: [tankerId], references: [id])
  fuelType      FuelProductType
  volume        Float
  pricePerLitre Decimal         @db.Decimal(10, 4)
  totalCost     Decimal         @db.Decimal(10, 2)
  depotName     String
  driverName    String?
  loadDate      DateTime
  notes         String?         @db.Text
  createdAt     DateTime        @default(now())

  @@map("tanker_loads")
}

// ─── Notification System ───────────────────────────────────────────────────────

model NotificationSetting {
  id               Int      @id @default(autoincrement())
  // BOOKING_UPDATE | DELIVERY_UPDATE | INVOICE_NOTIFICATION | OTP_NOTIFICATION
  // | TRIP_ALLOCATION | DISPATCH_ASSIGNMENT | SCHEDULE_CHANGE
  notificationType String   @unique
  emailEnabled     Boolean  @default(false)
  smsEnabled       Boolean  @default(false)
  whatsappEnabled  Boolean  @default(false)
  updatedAt        DateTime @updatedAt

  @@map("notification_settings")
}

model TwilioConfig {
  id           Int      @id @default(autoincrement())
  accountSid   String
  authToken    String
  fromPhone    String
  whatsappFrom String?  // e.g. whatsapp:+14155238886 — enables Twilio WhatsApp
  enabled      Boolean  @default(false)
  updatedAt    DateTime @updatedAt

  @@map("twilio_config")
}

model WhatsAppConfig {
  id            Int      @id @default(autoincrement())
  phoneNumberId String   // Meta phone number ID
  accessToken   String   // Meta permanent access token
  enabled       Boolean  @default(false)
  updatedAt     DateTime @updatedAt

  @@map("whatsapp_config")
}

model Notification {
  id             Int      @id @default(autoincrement())
  // BOOKING_UPDATE | DELIVERY_UPDATE | INVOICE_NOTIFICATION | OTP_NOTIFICATION
  // | TRIP_ALLOCATION | DISPATCH_ASSIGNMENT | SCHEDULE_CHANGE
  type           String
  channel        String   // EMAIL | SMS | WHATSAPP
  recipientType  String   // CUSTOMER | DRIVER
  recipientName  String?
  recipientEmail String?
  recipientPhone String?
  entityType     String   // TRIP | INVOICE
  entityId       Int
  subject        String?
  body           String   @db.Text
  status         String   @default("PENDING") // PENDING | SENT | FAILED
  sentAt         DateTime?
  failureReason  String?  @db.Text
  createdAt      DateTime @default(now())

  @@index([type])
  @@index([channel])
  @@index([status])
  @@index([entityType, entityId])
  @@map("notifications")
}
