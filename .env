# Server
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database
DATABASE_URL=mysql://user:password123@localhost:3306/perazim_db

# JWT
JWT_SECRET="change-this-to-a-strong-random-secret-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-this-to-another-strong-secret"
JWT_REFRESH_EXPIRES_IN="7d"

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@perazim.com

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-key

# Cartrack API
CARTRACK_BASE_URL=https://fleetapi-za.cartrack.com/rest/
CARTRACK_USERNAME=your-username
CARTRACK_PASSWORD=your-password